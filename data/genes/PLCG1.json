{"symbol": "PLCG1", "uniprot": "P19174", "protein_name": "1-phosphatidylinositol 4,5-bisphosphate phosphodiesterase gamma-1", "length": 1290, "function": "Mediates the production of the second messenger molecules diacylglycerol (DAG) and inositol 1,4,5-trisphosphate (IP3). Plays an important role in the regulation of intracellular signaling cascades. Becomes activated in response to ligand-mediated activation of receptor-type tyrosine kinases, such as PDGFRA, PDGFRB, EGFR, FGFR1, FGFR2, FGFR3 and FGFR4 (By similarity). Plays a role in actin reorganization and cell migration (PubMed:17229814). Guanine nucleotide exchange factor that binds the GTPase DNM1 and catalyzes the dissociation of GDP, allowing a GTP molecule to bind in its place, therefore enhancing DNM1-dependent endocytosis (By similarity)", "ensembl_gene": "ENSG00000124181", "scores": {"selectivity": 0.0252, "protein_drug": 0.557, "rna_drug": 0.688}, "flags": {"surface": false, "enzyme": true, "mod_aso": true, "mod_sirna": false}, "details": {"nominated_modality": "ASO", "winning_axis": "RNA", "quadrant": "Both viable", "best_route": "small molecule", "sm_score": "0.702", "sirna_score": "0.11", "aso_score": "0.592"}, "modality": "ASO", "structure": "data/structures/PLCG1.pdb", "pockets": [{"rank": 1, "druggability": 0.627, "volume": 959.2, "residues": [150, 151, 153, 154, 157, 210, 211, 214, 217, 218, 221, 222, 280, 281, 282, 283, 284, 286, 296, 297, 300, 1098]}, {"rank": 2, "druggability": 0.432, "volume": 1379.1, "residues": [187, 726, 727, 728, 729, 740, 741, 744, 745, 746, 747, 748, 1103, 1104, 1105, 1106, 1107, 1108, 1109, 1130, 1132, 1133, 1163, 1164, 1165, 1166, 1167, 1168, 1171, 1267, 1270, 1271]}, {"rank": 3, "druggability": 0.248, "volume": 1095.5, "residues": [1089, 1090, 1091, 1146, 1147, 1148, 1212, 1213, 1214, 1215, 1217, 1218, 1219, 1220, 1221, 1222, 1223]}], "links": [{"key": "uniprot", "label": "UniProt", "url": "https://www.uniprot.org/uniprotkb/P19174"}, {"key": "alphafold", "label": "Al